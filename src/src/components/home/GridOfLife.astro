---
// GridOfLife — decorative "carbon-aware system" matrix for the homepage hero.
//
// Living Ink direction: a sparse rectangular GRID of small rounded cells. A minority
// are "alive" (filled evergreen, varying sizes) blooming toward the bottom-right growth
// front; the rest are dormant faint-indigo outlines. A few orthogonally-adjacent alive
// cells are wired with hairline links, and one soft ambient glow sits over the bloom.
// Calm, schematic, data-like — reads as a system diagram of indigo giving way to green.
//
// - Purely decorative: aria-hidden, pointer-events: none, masked away from hero text,
//   tuned to LOW visual weight so it never reduces legibility of nearby text.
// - Deterministic: which cells are alive, their size, opacity and breathing phase all
//   derive from `seed`. Same seed -> identical render (build-stable, OG-safe).
// - Server-rendered SVG: works with NO JS. A tiny inline script opts in to a very slow,
//   low-amplitude breathing animation, skipped under prefers-reduced-motion (with a CSS
//   belt-and-braces guard). No-JS / reduced-motion visitors get the static grid.
// - Themeable via design tokens so it adapts to light/dark + daypart automatically:
//     --color-primary  dormant indigo cell outlines + nothing else
//     --color-living   alive (evergreen) cell fills + hairline links
//     --canopy-alive   focal "prime" cell fill (daypart-nudged tint)
//     --hero-glow      ambient wash behind the bloom (daypart-nudged)
//   Literal fallbacks are decorative only and never carry text, so they are exempt from
//   contrast requirements; they also keep it correct before the token migration lands.

interface Props {
  /** Numeric seed — deterministic layout. The page passes this in (do not read Date here). */
  seed?: number
  /** Decorative daypart hint (dawn/day/dusk/night). Non-contrast-bearing. */
  daypart?: 'dawn' | 'day' | 'dusk' | 'night'
  /** Grid dimensions (optional). */
  cols?: number
  rows?: number
}

const { seed = 1, daypart = 'day', cols = 8, rows = 12 } = Astro.props

// --- deterministic PRNG (mulberry32) --------------------------------------
function mulberry32(a: number) {
  let s = a >>> 0
  return () => {
    s = (s + 0x6d2b79f5) | 0
    let t = Math.imul(s ^ (s >>> 15), 1 | s)
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296
  }
}
const rnd = mulberry32((seed >>> 0) * 0x9e3779b1 + 0x2f1a9)

const W = 440
const H = 620
const MX = 34
const MY = 30
const COLS = Math.max(3, cols)
const ROWS = Math.max(3, rows)
const stepX = (W - MX * 2) / (COLS - 1)
const stepY = (H - MY * 2) / (ROWS - 1)
const round = (n: number) => Math.round(n * 10) / 10

// --- which cells are alive: probability blooms toward the bottom-right (the green end) ---
const alive: boolean[][] = []
for (let r = 0; r < ROWS; r++) {
  alive[r] = []
  for (let c = 0; c < COLS; c++) {
    const t = 0.46 * (r / (ROWS - 1)) + 0.54 * (c / (COLS - 1)) // 0 = top-left, 1 = bottom-right
    const p = 0.04 + 0.5 * t * t // eased so the indigo top-left stays sparse
    alive[r][c] = rnd() < p
  }
}

// --- decorative-only fills (used solely if a token is absent); never carry text ---
const livingFill = 'var(--color-living, #0B6E5F)'
const aliveFallback: Record<string, string> = {
  dawn: '#13a08a',
  day: '#0b6e5f',
  dusk: '#0e7e66',
  night: '#27b8a0',
}
const primeFill = `var(--canopy-alive, ${aliveFallback[daypart]})`

interface ACell {
  x: number
  y: number
  s: number
  rx: number
  op: number
  dur: number
  delay: number
  fill: string
  prime: boolean
}
interface DCell {
  x: number
  y: number
  s: number
  rx: number
  op: number
}

const aliveCells: ACell[] = []
const dormantCells: DCell[] = []
let sumX = 0
let sumY = 0
let aliveN = 0
let primeCount = 0

for (let r = 0; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    const cx = MX + c * stepX
    const cy = MY + r * stepY
    if (alive[r][c]) {
      const tr = rnd()
      let s = 13
      if (tr > 0.6) s = 17
      if (tr > 0.86) s = 21
      let prime = false
      if (s >= 21 && primeCount < 3 && rnd() < 0.85) {
        prime = true
        primeCount++
      }
      const op = prime ? round(0.84 + rnd() * 0.12) : round(0.5 + rnd() * 0.3)
      const dur = round(8 + rnd() * 4) // 8-12s
      const delay = round(rnd() * -dur) // negative -> phase offset, cells out of sync
      aliveCells.push({
        x: round(cx - s / 2),
        y: round(cy - s / 2),
        s,
        rx: round(s * 0.32),
        op,
        dur,
        delay,
        fill: prime ? primeFill : livingFill,
        prime,
      })
      sumX += cx
      sumY += cy
      aliveN++
    } else {
      const s = 11
      const op = round(0.13 + rnd() * 0.12)
      dormantCells.push({ x: round(cx - s / 2), y: round(cy - s / 2), s, rx: round(s * 0.34), op })
    }
  }
}

// --- hairline links between orthogonally-adjacent alive cells (a few "wired" nodes) ---
interface Ln {
  x1: number
  y1: number
  x2: number
  y2: number
}
const lines: Ln[] = []
for (let r = 0; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    if (!alive[r][c]) continue
    const cx = MX + c * stepX
    const cy = MY + r * stepY
    if (c + 1 < COLS && alive[r][c + 1]) lines.push({ x1: round(cx), y1: round(cy), x2: round(MX + (c + 1) * stepX), y2: round(cy) })
    if (r + 1 < ROWS && alive[r + 1][c]) lines.push({ x1: round(cx), y1: round(cy), x2: round(cx), y2: round(MY + (r + 1) * stepY) })
  }
}

// --- ambient glow centred on the bloom centroid ---
const gx = aliveN ? round(sumX / aliveN) : round(W * 0.62)
const gy = aliveN ? round(sumY / aliveN) : round(H * 0.62)
const glowFallback: Record<string, string> = {
  dawn: 'rgba(94, 234, 212, 0.18)',
  day: 'rgba(16, 185, 129, 0.16)',
  dusk: 'rgba(20, 184, 166, 0.18)',
  night: 'rgba(45, 212, 191, 0.14)',
}
const glowTint = `var(--hero-glow, ${glowFallback[daypart]})`

// Unique ids so multiple instances never collide.
const uid = `gol-${(seed >>> 0).toString(36)}`
---

<div class="gol" data-gol data-daypart={daypart} aria-hidden="true">
  <svg
    class="gol__svg"
    viewBox={`0 0 ${W} ${H}`}
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
    role="presentation"
    focusable="false"
  >
    <defs>
      <radialGradient id={`${uid}-glow`} cx={gx} cy={gy} r={H * 0.46} gradientUnits="userSpaceOnUse">
        <stop offset="0%" style={`stop-color: ${glowTint}`} />
        <stop offset="100%" style={`stop-color: ${glowTint}; stop-opacity: 0`} />
      </radialGradient>
    </defs>

    {/* ambient glow over the bloom */}
    <rect class="gol__glow" x="0" y="0" width={W} height={H} fill={`url(#${uid}-glow)`} />

    {/* hairline links between adjacent alive cells */}
    <g class="gol__links" fill="none" stroke="var(--color-living, #0B6E5F)" stroke-linecap="round" stroke-width="1">
      {lines.map((l) => <line x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2} vector-effect="non-scaling-stroke" />)}
    </g>

    {/* dormant cells — faint indigo outlines */}
    <g class="gol__dormant" fill="none" stroke="var(--color-primary, #4F46E5)" stroke-width="1.2">
      {
        dormantCells.map((d) => (
          <rect x={d.x} y={d.y} width={d.s} height={d.s} rx={d.rx} vector-effect="non-scaling-stroke" style={`opacity:${d.op}`} />
        ))
      }
    </g>

    {/* alive cells — filled evergreen, gently breathing */}
    <g class="gol__alive">
      {
        aliveCells.map((a) => (
          <rect
            class={a.prime ? 'gol__cell gol__cell--prime' : 'gol__cell'}
            x={a.x}
            y={a.y}
            width={a.s}
            height={a.s}
            rx={a.rx}
            fill={a.fill}
            style={`--op:${a.op};--dur:${a.dur}s;--delay:${a.delay}s;opacity:${a.op}`}
          />
        ))
      }
    </g>
  </svg>
</div>

<script is:inline>
  // Tiny progressive enhancement: enable the slow CSS breathing only when the visitor
  // has not asked to reduce motion. No-JS / reduced-motion -> static server-rendered grid.
  (function () {
    if (window.__golBreatheInit) return
    window.__golBreatheInit = true
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return
    var els = document.querySelectorAll('[data-gol]')
    for (var i = 0; i < els.length; i++) els[i].classList.add('gol--breathe')
  })()
</script>

<style>
  .gol {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .gol__svg {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: 60%;
    min-width: 430px;
    /* keep total weight low and dissolve the field away from the (left-aligned) hero text */
    opacity: 0.62;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0, 0, 0, 0.35) 26%, #000 58%);
    mask-image: linear-gradient(to right, transparent 0%, rgba(0, 0, 0, 0.35) 26%, #000 58%);
  }

  :global([data-theme='dark']) .gol__svg {
    opacity: 0.74;
  }

  .gol__links {
    opacity: 0.16;
  }

  /* indigo reads faint on the dark substrate — lift the dormant outlines a touch */
  :global([data-theme='dark']) .gol__dormant {
    stroke: var(--color-primary, #818cf8);
  }

  .gol__cell {
    transform-box: fill-box;
    transform-origin: 50% 50%;
  }

  /* On narrow screens the field sits behind full-width text — pull it back hard. */
  @media (max-width: 767px) {
    .gol__svg {
      width: 78%;
      min-width: 0;
      opacity: 0.32;
      -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0, 0, 0, 0.3) 38%, #000 72%);
      mask-image: linear-gradient(to right, transparent 0%, rgba(0, 0, 0, 0.3) 38%, #000 72%);
    }
    :global([data-theme='dark']) .gol__svg {
      opacity: 0.42;
    }
  }

  /* --- Very slow, low-amplitude breathing (opt-in via the inline script) --- */
  .gol--breathe .gol__cell {
    animation: gol-breathe var(--dur, 10s) ease-in-out var(--delay, 0s) infinite;
    will-change: transform;
  }
  .gol--breathe .gol__glow {
    animation: gol-glow 13s ease-in-out infinite;
  }

  @keyframes gol-breathe {
    0%,
    100% {
      transform: scale(0.95);
      opacity: calc(var(--op) * 0.8);
    }
    50% {
      transform: scale(1.045);
      opacity: var(--op);
    }
  }

  @keyframes gol-glow {
    0%,
    100% {
      opacity: 0.82;
    }
    50% {
      opacity: 1;
    }
  }

  /* Belt-and-braces: never animate under reduced-motion, even if the class is set. */
  @media (prefers-reduced-motion: reduce) {
    .gol__cell,
    .gol__glow {
      animation: none !important;
    }
  }
</style>