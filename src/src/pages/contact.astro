---
import BaseLayout from '../layouts/BaseLayout.astro'
import Container from '../components/containers/Container.astro'
import PageHeader from '../components/partials/PageHeader.astro'
import { contact } from '../config/personal'

const channels = [
  {
    label: 'Email',
    value: contact.email,
    href: `mailto:${contact.email}`,
    note: 'Best for advisory, consulting, and anything substantive.',
    cat: 'green',
    external: false,
  },
  {
    label: 'LinkedIn',
    value: 'in/chrislloydjones',
    href: contact.linkedin,
    note: 'Connect, or send a message if we have not met.',
    cat: 'ai',
    external: true,
  },
  {
    label: 'Mastodon',
    value: '@sealjay@fosstodon.org',
    href: 'https://fosstodon.org/@sealjay',
    note: 'Where I am most active in the open.',
    cat: 'oss',
    external: true,
  },
  {
    label: 'Bluesky',
    value: '@sealjay.com',
    href: 'https://bsky.app/profile/sealjay.com',
    note: 'Shorter thoughts and conversation.',
    cat: 'dev',
    external: true,
  },
]

const helpWith = [
  'AI transformation & governance — strategy, guardrails, and agentic AI in the enterprise',
  'Green software & sustainability — measuring and reducing the footprint of what we build',
  'Open source — programmes, community, and doing it credibly',
  'Speaking, panels & advisory — keynotes, workshops, and board-level briefings',
]
---

<BaseLayout
  title="Contact"
  description="Get in touch with Chris Lloyd-Jones — AI transformation and governance, green software, open source, speaking and advisory."
>
  <Container>
    <PageHeader
      title="Get in touch"
      subtitle="Speaking, advisory, and collaboration"
      center={false}
      breadcrumbs={[
        { label: 'Home', href: '/' },
        { label: 'Contact' },
      ]}
    />

    <div class="contact">
      <p class="contact__lede">
        The fastest way to reach me is <a href={`mailto:${contact.email}`} class="contact__inline">email</a> or LinkedIn.
        I read everything, and I am always happy to talk about the things below.
      </p>

      <ul class="contact__help">
        {helpWith.map((item) => <li>{item}</li>)}
      </ul>

      <div class="contact__grid">
        {channels.map((c) => (
          <a
            href={c.href}
            class="contact__card"
            style={`--accent: var(--color-cat-${c.cat}); --accent-bg: var(--color-cat-${c.cat}-bg);`}
            {...(c.external ? { target: '_blank', rel: 'me noopener noreferrer' } : {})}
          >
            <span class="contact__label">{c.label}</span>
            <span class="contact__value">{c.value}{c.external && <span class="sr-only"> (opens in new tab)</span>}</span>
            <span class="contact__note">{c.note}</span>
          </a>
        ))}
      </div>

      <p class="contact__kit">
        Booking me to speak? The <a href="/speaking/kit" class="contact__inline">speaker kit</a> has bios, a headshot, topics, and formats ready to forward.
      </p>
    </div>
  </Container>
</BaseLayout>

<style>
  .contact {
    max-width: 46rem;
    padding-bottom: 3rem;
  }

  .contact__lede {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }

  .contact__inline {
    color: var(--color-living);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .contact__help {
    list-style: none;
    margin: 0 0 2.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .contact__help li {
    position: relative;
    padding-left: 1.5rem;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .contact__help li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 2px;
    background: var(--color-living-accent);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 560px) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact__card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--color-card-glow);
    text-decoration: none;
    border-left: 3px solid var(--accent);
    transition: transform var(--duration-normal) var(--ease-out),
                border-color var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .contact__card:hover {
    transform: translateY(-2px);
    box-shadow: var(--color-card-glow), var(--color-card-glow-hover);
  }

  .contact__card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .contact__label {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .contact__value {
    font-family: var(--font-code);
    font-size: 0.9375rem;
    color: var(--color-text);
    word-break: break-word;
  }

  .contact__note {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .contact__kit {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
